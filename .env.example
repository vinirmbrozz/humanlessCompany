# Template do .env — copie para `.env` e preencha. NUNCA comite o `.env` real (já está no .gitignore).
#   cp .env.example .env

# --- Agentes Claude (adapter claude-local) — preencha UMA das duas ---
# Assinatura (recomendado p/ headless): gere com `claude setup-token`, começa com sk-ant-oat...
CLAUDE_CODE_OAUTH_TOKEN=
# Alternativa: cobrança por token via API Anthropic.
ANTHROPIC_API_KEY=

# --- Agentes Codex (adapter codex-local) — opcional ---
# API key da OpenAI (sk-proj-...), billing por token.
OPENAI_API_KEY=

# --- Banco de dados (Postgres) ---
# A senha vive SÓ aqui. Ao TROCAR depois, também rode no banco vivo:
#   docker exec -i paperclip-db psql -U paperclip -d paperclip -c "ALTER USER paperclip PASSWORD '<nova>';"
POSTGRES_USER=paperclip
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=paperclip

# --- Caminhos dos repositórios espelhados (config de ambiente, não é segredo) ---
# Pasta base no host onde ficam os projetos. Mudou de lugar? Troque só esta linha.
DIR_PATH=C:/Users/<voce>/caminho/para/os/projetos
